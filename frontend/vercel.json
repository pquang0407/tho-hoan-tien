{
  "rewrites": [
    {
      "source": "/:code",
      "has": [
        { "type": "host", "value": "shopee.tho-hoantien.com" }
      ],
      "destination": "https://tho-hoan-tien-backend.onrender.com/thohoantien-sp/:code"
    },
    {
      "source": "/:code",
      "has": [
        { "type": "host", "value": "tiktok.tho-hoantien.com" }
      ],
      "destination": "https://tho-hoan-tien-backend.onrender.com/thohoantien-tik/:code"
    },
    {
      "source": "/:code",
      "has": [
        { "type": "host", "value": "lazada.tho-hoantien.com" }
      ],
      "destination": "https://tho-hoan-tien-backend.onrender.com/thohoantien-laz/:code"
    },
    {
      "source": "/(.*)",
      "destination": "/index.html"
    }
  ]
}
